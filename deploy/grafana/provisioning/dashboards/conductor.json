{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Conductor",
  "uid": "conductor",
  "schemaVersion": 39,
  "tags": ["conductor"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Jobs by status (rate /s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (status) (rate(conductor_jobs_total[5m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Jobs by type (rate /s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (type) (rate(conductor_jobs_total[5m]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows processed (rate /s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(conductor_rows_processed_total[1m]))", "legendFormat": "rows/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job duration p95 (s) by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, type) (rate(conductor_job_duration_seconds_bucket[5m])))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "conductor_queue_depth", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker in-flight",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "conductor_worker_in_flight", "legendFormat": "{{worker}}" }
      ]
    }
  ]
}
