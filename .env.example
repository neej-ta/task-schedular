# ─────────────────────────────────────────────────────────────────────────────
# Conductor — local dev configuration (12-factor). Copy to .env and adjust.
# NEVER commit a real .env. No production secrets in the repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Control-plane database (Conductor's own DB — NOT a target project DB) ──────
CONTROL_DB_HOST=postgres
CONTROL_DB_PORT=5432
CONTROL_DB_NAME=conductor
CONTROL_DB_USER=conductor
CONTROL_DB_PASSWORD=conductor_dev_pw
# Full URL form used by services/scripts:
DATABASE_URL=postgres://conductor:conductor_dev_pw@postgres:5432/conductor

# ── Demo target project DB (what the seeded demo Project points at) ────────────
# Now a separate database/user on the main postgres instance (folded in from
# the former standalone demo-target container).
DEMO_TARGET_HOST=postgres
DEMO_TARGET_PORT=5432
DEMO_TARGET_DB=demo
DEMO_TARGET_USER=demo
DEMO_TARGET_PASSWORD=demo_dev_pw

# Folded-in mock-REST endpoint (rest_pull / rest_push demos) runs inside the app
# container on loopback.
MOCK_REST_URL=http://127.0.0.1:4000/customers

# ── Secret encryption (envelope encryption master key / KEK) ───────────────────
# Local dev key ONLY. 32 bytes, base64-encoded (AES-256). Generate a real one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONDUCTOR_MASTER_KEY=Y29uZHVjdG9yLWRldi1tYXN0ZXIta2V5LTMyYnl0ZXM=
CONDUCTOR_MASTER_KEY_ID=dev-local-v1

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Local dev signing secret. Replace OIDC/JWT in prod (see docs/DECISIONS.md).
JWT_SECRET=dev-only-change-me-in-prod-please-32+chars
JWT_ISSUER=conductor
JWT_EXPIRES_IN=12h

# ── Gateway API ─────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ── SSRF egress guard for target-DB connections ────────────────────────────────
# Deny private/loopback/metadata by default. Comma-separated allow-list of
# hostnames or CIDRs an Admin has explicitly approved. The Docker network names
# below are allow-listed so the seeded demo works in local dev.
SSRF_ALLOWLIST=postgres,127.0.0.1/32

# ── Infrastructure ──────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://conductor:conductor_dev_pw@rabbitmq:5672
REDIS_URL=redis://valkey:6379
S3_ENDPOINT=http://seaweedfs:8333
S3_ACCESS_KEY=conductor
S3_SECRET_KEY=conductor_dev_pw
S3_BUCKET=uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── Dashboard (Vite) ────────────────────────────────────────────────────────────
# Dev server (vite --host) talks to the gateway cross-origin. In the container
# the dashboard is built with an empty base and served same-origin (see
# dashboard/.env.production).
VITE_API_BASE=http://localhost:8080
